	measure 'Logística HTML' =
			
			VAR PesoTot = FORMAT([Peso Total Operativo], "#,##0.00")
			VAR CajasTot = FORMAT([Cajas Totales Operativas], "#,##0")
			VAR VarPeso = FORMAT([Variación Peso % vs AA], "+0.0%;-0.0%;0.0%")
			VAR VarCajas = FORMAT([Variación Cajas % vs AA], "+0.0%;-0.0%;0.0%")
			VAR ColorPeso = IF([Variación Peso % vs AA] >= 0, "#16a34a", "#dc2626")
			VAR ColorCajas = IF([Variación Cajas % vs AA] >= 0, "#16a34a", "#dc2626")
			RETURN
			"<div style='font-family:Segoe UI; background:linear-gradient(180deg,#f8fafc,#eff6ff); border:1px solid #dbeafe; border-radius:18px; padding:14px;'>
			<div style='display:flex;justify-content:space-between;align-items:center; margin-bottom:8px;'>
			<div><div style='font-size:24px;font-weight:800;color:#0f172a;'>Análisis Logístico</div><div style='font-size:12px;color:#475569;'>Destino, volumen y comparativo anual</div></div>
			<div style='display:grid; grid-template-columns:2fr 1fr; gap:10px; margin-bottom:10px;'>
			  <div style='background:white; border:1px solid #dbeafe; border-radius:14px; padding:12px;'>
			    <div style='font-size:14px; font-weight:700; color:#0f172a; margin-bottom:8px;'>KPIs de operación y productividad</div>
			    <div style='display:grid; grid-template-columns:repeat(4,1fr); gap:8px;'>
			      <div style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px;'>
			        <div style='font-size:11px; color:#64748b;'>Productividad (pzs/pedido)</div>
			        <div style='font-size:21px; font-weight:800; color:#0f172a; margin-top:2px;'>" & ProductividadFmt & "</div>
			      </div>
			      <div style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px;'>
			        <div style='font-size:11px; color:#64748b;'>Eficiencia (pzs/hora)</div>
			        <div style='font-size:21px; font-weight:800; color:#0f172a; margin-top:2px;'>" & EficienciaFmt & "</div>
			      </div>
			      <div style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px;'>
			        <div style='font-size:11px; color:#64748b;'>Cerrados / En proceso</div>
			        <div style='font-size:21px; font-weight:800; color:#0f172a; margin-top:2px;'>" & CerradosFmt & " / " & EnProcesoFmt & "</div>
			      </div>
			      <div style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px;'>
			        <div style='font-size:11px; color:#64748b;'>Antes / Después de 12:00</div>
			        <div style='font-size:21px; font-weight:800; color:#0f172a; margin-top:2px;'>" & Antes12Fmt & " / " & Despues12Fmt & "</div>
			      </div>
			    </div>
			  </div>
			  <div style='background:white; border:1px solid #dbeafe; border-radius:14px; padding:12px;'>
			    <div style='font-size:14px; font-weight:700; color:#0f172a; margin-bottom:8px;'>Volumen y variaciones</div>
			    <div style='display:grid; grid-template-columns:1fr; gap:8px;'>
			      <div style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px;'>
			        <div style='font-size:11px; color:#64748b;'>Piezas requeridas</div>
			        <div style='font-size:21px; font-weight:800; color:#0f172a; margin-top:2px;'>" & PiezasReqFmt & "</div>
			      </div>
			      <div style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px;'>
			        <div style='font-size:11px; color:#64748b;'>Piezas surtidas</div>
			        <div style='font-size:21px; font-weight:800; color:#0f172a; margin-top:2px;'>" & PiezasSurFmt & "</div>
			      </div>
			      <div style='background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:10px;'>
			        <div style='font-size:11px; color:#64748b;'>Variación volumen (sur - req)</div>
			        <div style='font-size:21px; font-weight:800; color:" & ColorVariacion & "; margin-top:2px;'>" & VariacionVolFmt & "</div>
			        <div style='font-size:12px; font-weight:700; color:" & ColorVariacion & ";'>" & VariacionPctFmt & "</div>
			      </div>
			    </div>
			  </div>
			</div>
			<div style='display:grid;grid-template-columns:repeat(4,1fr);gap:8px;'>
			<div style='background:#1d4ed8;color:white;border-radius:12px;padding:10px;'><div style='font-size:11px;opacity:.85'>Peso total</div><div style='font-size:23px;font-weight:800;'>" & PesoTot & "</div></div>
			<div style='background:white;border:1px solid #dbeafe;border-radius:12px;padding:10px;'><div style='font-size:11px;color:#64748b'>Cajas totales</div><div style='font-size:23px;font-weight:800;color:#0f172a;'>" & CajasTot & "</div></div>
			<div style='background:white;border:1px solid #dbeafe;border-radius:12px;padding:10px;'><div style='font-size:11px;color:#64748b'>Variación peso vs AA</div><div style='font-size:23px;font-weight:800;color:" & ColorPeso & ";'>" & VarPeso & "</div></div>
			<div style='background:white;border:1px solid #dbeafe;border-radius:12px;padding:10px;'><div style='font-size:11px;color:#64748b'>Variación cajas vs AA</div><div style='font-size:23px;font-weight:800;color:" & ColorCajas & ";'>" & VarCajas & "</div></div>
			</div></div>"
		lineageTag: 44582f32-9189-41fd-95b2-df61f0a094bc



	measure 'Total Pedidos AA' =
			
			<div style='display:grid; grid-template-columns:repeat(4,1fr); gap:10px;'>
			  <div style='background:white; border:1px solid #dbeafe; border-radius:14px; padding:10px;'>
			    <div style='font-size:11px; color:#64748b;'>Complejidad ≤ 50 piezas</div>
			    <div style='font-size:22px; font-weight:800; color:#0f172a; margin-top:2px;'>" & Menor50Fmt & "</div>
